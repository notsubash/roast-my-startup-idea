LOCAL_MODEL=ollama:qwen3.5:9b
MAX_DEBATE_ROUNDS=3
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
ENABLE_WEB_SEARCH=false
WEB_SEARCH_MAX_RESULTS=3
TAVILY_API_KEY=your_tavily_api_key
ROAST_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SSE_HEARTBEAT_SECONDS=15
STALE_RUN_MINUTES=30
RUNS_DB_PATH=data/runs.db

# Operability
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW_SECONDS=60
MAX_RUN_SECONDS=600
TRUST_PROXY=false

# LangSmith observability (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=roast-my-startup
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Semantic memory (optional)
ENABLE_SEMANTIC_MEMORY=false
EMBEDDING_MODEL=ollama:nomic-embed-text
EMBEDDING_DIMENSION=768

# Revote
ENABLE_REVOTE=true          # set false to skip re-vote (rollback)
MAX_REVOTE_SCORE_DELTA=3    # max points per judge per re-vote
MAX_RUN_SECONDS=600         # existing wall-clock budget